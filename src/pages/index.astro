---
// src/pages/index.astro
import "../styles/global.css";
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Ahmad Syahani Repo</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
        [x-cloak] { display: none !important; }
        /* Scrollbar Dark Theme */
        .scroller::-webkit-scrollbar { width: 6px; height: 6px; }
        .scroller::-webkit-scrollbar-track { background: transparent; }
        .scroller::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 10px; }
        .scroller::-webkit-scrollbar-thumb:hover { background: #52525b; }
        
        .modal-enter { opacity: 1; pointer-events: auto; transform: scale(1); }
        .modal-exit { opacity: 0; pointer-events: none; transform: scale(0.95); }
        .toast-enter { transform: translateY(0); opacity: 1; }
        .toast-exit { transform: translateY(100px); opacity: 0; }
    </style>
</head>

<body class="bg-[#121212] text-zinc-300 h-screen w-screen overflow-hidden flex font-sans selection:bg-blue-500/30">

    <aside class="w-64 bg-[#121212] border-r border-white/5 flex flex-col hidden md:flex shrink-0">
        <div class="h-16 flex items-center px-5 shrink-0">
            <button class="flex items-center gap-2 text-zinc-100 font-bold hover:bg-white/5 px-2 py-1.5 rounded-lg transition-colors">
                <div class="w-6 h-6 bg-blue-600 rounded flex items-center justify-center text-white">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
                </div>
                TaskRepo <span class="text-zinc-500 ml-1">▼</span>
            </button>
        </div>

        <nav class="flex-1 overflow-y-auto px-3 py-2 space-y-0.5">
            <button onclick="window.navigate('recent')" id="nav-recent" class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-zinc-400 hover:text-zinc-100 hover:bg-white/5 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Recent Files
            </button>
            
            <div class="mt-6 mb-2 px-3 flex items-center gap-2">
                <span class="text-xs font-semibold text-zinc-500">My drives</span>
            </div>
            
            <div class="space-y-0.5">
                <button onclick="window.navigate('home')" id="nav-home" class="w-full flex items-center gap-3 px-3 py-1.5 rounded-lg text-sm font-medium text-zinc-100 bg-white/10 transition-colors">
                    <div class="w-1.5 h-1.5 bg-blue-500 rounded-full"></div>
                    Semua Materi
                </button>
                <div class="pl-6 space-y-0.5 mt-1 border-l border-white/5 ml-4" id="category-list">
                    </div>
            </div>
        </nav>

        <div class="p-4 border-t border-white/5">
            <div class="w-full bg-white/10 rounded-full h-1.5 mb-2"><div class="bg-blue-500 h-1.5 rounded-full w-1/3"></div></div>
            <div class="flex items-center justify-between text-xs text-zinc-500">
                <span>18.5 GB of 50 GB used</span>
            </div>
            <button onclick="window.openLoginModal()" id="btn-login-modal" class="mt-4 w-full flex items-center justify-center gap-2 py-2 text-xs font-semibold text-zinc-400 hover:text-zinc-100 bg-white/5 hover:bg-white/10 rounded-lg transition-colors">
                Admin Login
            </button>
            <button onclick="window.executeLogout()" id="btn-logout" class="hidden mt-4 w-full flex items-center justify-center gap-2 py-2 text-xs font-semibold text-red-400 hover:text-red-300 bg-white/5 hover:bg-white/10 rounded-lg transition-colors">
                Logout Admin
            </button>
        </div>
    </aside>

    <main class="flex-1 flex flex-col min-w-0 bg-[#161618] rounded-l-2xl border-l border-y border-white/5 my-2 mr-2 overflow-hidden shadow-2xl relative">
        
        <header class="h-16 flex items-center justify-between px-6 border-b border-white/5 shrink-0 z-10 bg-[#161618]/80 backdrop-blur-md">
            <div class="flex items-center gap-2 text-sm font-medium" id="breadcrumb-container">
                <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                <span class="text-zinc-100">TaskRepo</span>
            </div>

            <div class="flex items-center gap-3">
                <button id="btn-upload" onclick="window.openAddModal()" class="hidden bg-blue-600 hover:bg-blue-500 text-white text-xs font-semibold py-1.5 px-4 rounded-md transition-all items-center gap-2 shadow-lg shadow-blue-500/20 active:scale-95">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    Upload File
                </button>
            </div>
        </header>

        <div class="flex items-center justify-between px-6 py-4 shrink-0">
            <div class="flex items-center gap-2">
                <button onclick="window.toggleSort()" class="flex items-center gap-2 px-3 py-1.5 rounded-md text-xs font-medium text-zinc-400 hover:text-zinc-100 hover:bg-white/5 border border-white/10 transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg>
                    <span id="sort-label">Sort By Date</span>
                </button>
                <div class="relative hidden sm:block ml-2 border border-white/10 rounded-md bg-[#1C1C1E]">
                    <svg class="w-3.5 h-3.5 absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    <input type="text" id="search-input" placeholder="Search..." class="pl-8 pr-3 py-1.5 text-xs bg-transparent focus:outline-none focus:ring-1 focus:ring-white/20 w-48 text-zinc-200 placeholder-zinc-500">
                </div>
            </div>

            <div class="flex items-center gap-2 text-xs font-medium text-zinc-400">
                <span id="status-count">0 items</span>
                <div class="w-[1px] h-4 bg-white/10 mx-2"></div>
                <div class="flex bg-[#1C1C1E] border border-white/10 rounded-md p-0.5">
                    <button id="toggle-grid" class="p-1.5 rounded bg-white/10 text-zinc-100 shadow-sm transition-all"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg></button>
                    <button id="toggle-list" class="p-1.5 rounded hover:text-zinc-200 hover:bg-white/5 transition-all"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg></button>
                </div>
            </div>
        </div>

        <div id="list-header" class="hidden grid-cols-12 gap-4 px-8 py-2 border-b border-white/5 text-xs font-semibold text-zinc-500 tracking-wider mb-2">
            <div class="col-span-5">Name</div>
            <div class="col-span-2">Format</div>
            <div class="col-span-2">Size</div>
            <div class="col-span-2">Date Modified</div>
            <div class="col-span-1 text-right" id="list-header-aksi">Action</div>
        </div>

        <div id="content-area" class="scroller flex-1 overflow-y-auto grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 content-start pb-10 px-6">
            </div>

        <div id="loading-spinner" class="absolute inset-0 bg-[#161618]/80 backdrop-blur-sm z-10 flex flex-col items-center justify-center modal-exit transition-all duration-300">
            <div class="w-8 h-8 border-2 border-white/10 border-t-blue-500 rounded-full animate-spin"></div>
            <p class="text-xs font-medium text-zinc-400 mt-4" id="loading-text">Processing...</p>
        </div>
    </main>

    <div id="toast" class="fixed bottom-6 right-6 px-4 py-3 rounded-lg shadow-xl flex items-center gap-3 z-[100] toast-exit transition-all duration-300 font-medium text-xs bg-[#242427] text-zinc-100 border border-white/10">
        <span id="toast-icon"></span>
        <span id="toast-msg"></span>
    </div>

    <div id="form-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center modal-exit transition-all duration-300">
        <div class="bg-[#1C1C1E] border border-white/10 shadow-2xl rounded-xl w-full max-w-md overflow-hidden" id="form-modal-box">
            <div class="px-6 py-4 border-b border-white/5 flex justify-between items-center">
                <h2 id="modal-title" class="text-sm font-semibold text-zinc-100">Upload Data</h2>
                <button onclick="window.closeModal('form-modal')" class="text-zinc-500 hover:text-zinc-300 transition-colors"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
            </div>
            <div class="p-6 space-y-4">
                <input type="hidden" id="input-id">
                <div>
                    <label class="block text-xs font-medium text-zinc-400 mb-1.5">File Title</label>
                    <input type="text" id="input-label" placeholder="e.g., Laporan Praktikum" class="w-full px-3 py-2 bg-[#242427] border border-white/5 rounded-md focus:border-blue-500 focus:ring-0 outline-none text-sm transition-all text-zinc-100 placeholder-zinc-600">
                </div>
                <div>
                    <label class="block text-xs font-medium text-zinc-400 mb-1.5">File Attachment</label>
                    <input type="file" id="input-file" class="w-full bg-[#242427] border border-white/5 rounded-md outline-none text-sm transition-all file:mr-3 file:py-2 file:px-4 file:border-0 file:text-xs file:font-medium file:bg-white/10 file:text-zinc-200 hover:file:bg-white/20 cursor-pointer text-zinc-400">
                </div>
                <div>
                    <label class="block text-xs font-medium text-zinc-400 mb-1.5">Destination Folder</label>
                    <select id="input-parent" class="w-full px-3 py-2 bg-[#242427] border border-white/5 rounded-md focus:border-blue-500 outline-none text-sm transition-all text-zinc-100 appearance-none">
                        <option value="folder_algo">ASD</option>
                        <option value="folder_bd">Basis Data</option>
                        <option value="folder_web">Pemrog. Web</option>
                        <option value="folder_sop">Sistem Operasi</option>
                    </select>
                </div>
            </div>
            <div class="px-6 py-4 bg-[#161618] flex justify-end gap-3 border-t border-white/5">
                <button onclick="window.closeModal('form-modal')" class="px-4 py-2 text-xs font-medium text-zinc-400 hover:text-zinc-200 hover:bg-white/5 rounded-md transition-colors">Cancel</button>
                <button onclick="window.saveData()" class="px-4 py-2 text-xs font-medium bg-blue-600 hover:bg-blue-500 text-white rounded-md shadow-sm transition-all active:scale-95">Save File</button>
            </div>
        </div>
    </div>

    <div id="delete-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center modal-exit transition-all duration-300">
        <div class="bg-[#1C1C1E] border border-white/10 shadow-2xl rounded-xl w-full max-w-sm p-6 text-center" id="delete-modal-box">
            <h2 class="text-base font-semibold text-zinc-100 mb-1">Delete File?</h2>
            <p class="text-xs text-zinc-400 mb-6">Are you sure you want to delete this file? This action cannot be undone.</p>
            <input type="hidden" id="delete-id">
            <div class="flex justify-center gap-3">
                <button onclick="window.closeModal('delete-modal')" class="flex-1 py-2 text-xs font-medium text-zinc-300 bg-white/5 hover:bg-white/10 rounded-md transition-colors">Cancel</button>
                <button onclick="window.executeDelete()" class="flex-1 py-2 text-xs font-medium bg-red-600/90 hover:bg-red-500 text-white rounded-md shadow-sm transition-all active:scale-95">Delete</button>
            </div>
        </div>
    </div>
    
    <div id="login-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center modal-exit transition-all duration-300">
        <div class="bg-[#1C1C1E] border border-white/10 shadow-2xl rounded-xl w-full max-w-sm overflow-hidden" id="login-modal-box">
            <div class="px-6 py-5 border-b border-white/5 flex justify-between items-center">
                <h2 class="text-sm font-semibold text-zinc-100">Admin Access</h2>
                <button onclick="window.closeModal('login-modal')" class="text-zinc-500 hover:text-zinc-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-xs font-medium text-zinc-400 mb-1.5">Email</label>
                    <input type="email" id="login-email" placeholder="admin@example.com" class="w-full px-3 py-2 bg-[#242427] border border-white/5 rounded-md focus:border-blue-500 outline-none text-sm transition-all text-zinc-100">
                </div>
                <div>
                    <label class="block text-xs font-medium text-zinc-400 mb-1.5">Password</label>
                    <input type="password" id="login-password" placeholder="••••••••" class="w-full px-3 py-2 bg-[#242427] border border-white/5 rounded-md focus:border-blue-500 outline-none text-sm transition-all text-zinc-100">
                </div>
                <button onclick="window.executeLogin()" class="w-full py-2.5 mt-2 text-xs font-semibold bg-white text-black hover:bg-zinc-200 rounded-md shadow-sm transition-all active:scale-95">Sign In</button>
            </div>
        </div>
    </div>

    <script src="../scripts/app.js"></script>
</body>
</html>